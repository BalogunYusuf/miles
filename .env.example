# Server settings
PORT=3000
NODE_ENV=production
CORS_ORIGIN=*

# Optional email notification settings
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-username
EMAIL_PASS=your-smtp-password
EMAIL_FROM="JW Courtship Advisory <no-reply@jwcourtship.org>"
EMAIL_TO=advisory@jwcourtship.org
EMAIL_SUBJECT_PREFIX=[JW Courtship Advisory]

# Optional rate limit settings
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=120
